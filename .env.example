# AI 同声传译助手 - 环境变量模板
#
# 复制为 .env 并填入真实 API Key：
#   cp .env.example .env
#
# 当前使用阿里云百炼 LiveTranslate 实现端到端实时语音翻译
# （ASR + 翻译合并在一个 WebSocket 流中）

# 阿里云百炼 DashScope API Key（必填）
# 获取：登录 dashscope.aliyun.com → API-KEY 管理
DASHSCOPE_API_KEY=your-dashscope-api-key-here

# 服务配置（可选）
# HOST=127.0.0.1
# PORT=8000
